{
    "name": "tidbcloud/lake-php",
    "description": "PHP driver for TiDB Cloud Lake (HTTP API)",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["tidbcloud", "lake", "database", "driver", "sql"],
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "TiDBCloud\\Lake\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TiDBCloud\\Lake\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
